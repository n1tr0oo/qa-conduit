{
  "name": "qa-conduit",
  "version": "1.0.0",
  "description": "**Conduit RealWorld App** — a blogging platform built with React / Express.js / Sequelize / PostgreSQL.\r - Repository: https://github.com/TonyMckes/conduit-realworld-example-app\r - Local Frontend: http://localhost:3000\r - Local Backend: http://localhost:3001",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:unit:allure": "node tests/unit/generate-allure-results.mjs",
    "test:api": "newman run tests/api/conduit.postman_collection.json --reporters cli,junit,allure --reporter-junit-export reports/junit/newman-results.xml --reporter-allure-export allure-results",
    "test:api:edge": "newman run tests/api/conduit-edge-cases.postman_collection.json --reporters cli,junit,allure --reporter-junit-export reports/junit/newman-edge-results.xml --reporter-allure-export allure-results",
    "test:report": "playwright show-report reports/html",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:mutation": "node tests/mutation/run-mutation-tests.mjs",
    "test:mutation:verbose": "node tests/mutation/run-mutation-tests.mjs --verbose",
    "test:chaos": "node tests/chaos/run-all.mjs",
    "test:chaos:downtime": "node tests/chaos/api-downtime.mjs",
    "test:chaos:db": "node tests/chaos/db-failure.mjs",
    "test:chaos:latency": "node tests/chaos/network-latency.mjs",
    "test:chaos:exhaustion": "node tests/chaos/resource-exhaustion.mjs",
    "test:perf:auth": "k6 run tests/performance/k6/auth-load-test.js",
    "test:perf:articles": "k6 run tests/performance/k6/articles-load-test.js",
    "test:perf:feed": "k6 run tests/performance/k6/feed-load-test.js",
    "test:perf:full": "k6 run tests/performance/k6/full-scenario.js",
    "test:perf:full:stress": "k6 run --env SCENARIO=stress tests/performance/k6/full-scenario.js",
    "test:perf:full:spike": "k6 run --env SCENARIO=spike tests/performance/k6/full-scenario.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1tr0oo/qa-conduit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/n1tr0oo/qa-conduit/issues"
  },
  "homepage": "https://github.com/n1tr0oo/qa-conduit#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "newman": "^6.2.2",
    "newman-reporter-allure": "^3.7.1"
  }
}
