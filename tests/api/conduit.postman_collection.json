{
  "info": {
    "name": "Conduit API Tests",
    "description": "API test collection for Conduit RealWorld App — covers HIGH and MEDIUM risk modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" },
    { "key": "token", "value": "" },
    { "key": "articleSlug", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication (HIGH)",
      "item": [
        {
          "name": "Register new user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.expect(json.user).to.have.property('token');",
                  "  pm.expect(json.user).to.have.property('email');",
                  "  pm.collectionVariables.set('token', json.user.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"username\": \"testuser_{{$timestamp}}\",\n    \"email\": \"test_{{$timestamp}}@example.com\",\n    \"password\": \"password123\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Login with valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns JWT token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.have.property('token');",
                  "  pm.expect(json.user.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('token', json.user.token);",
                  "});",
                  "pm.test('Returns correct email', () => {",
                  "  pm.expect(pm.response.json().user.email).to.eql('qa_test@example.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"qa_test@example.com\",\n    \"password\": \"password123\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users/login"
          }
        },
        {
          "name": "Login with wrong password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Returns errors object', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('errors');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"qa_test@example.com\",\n    \"password\": \"wrongpassword\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users/login"
          }
        },
        {
          "name": "Get current user (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user data', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.expect(json.user).to.have.property('email');",
                  "  pm.expect(json.user).to.have.property('username');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{baseUrl}}/user"
          }
        },
        {
          "name": "Get current user (no token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/user"
          }
        }
      ]
    },
    {
      "name": "Articles (HIGH)",
      "item": [
        {
          "name": "Get global feed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns articles array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('articles');",
                  "  pm.expect(json.articles).to.be.an('array');",
                  "  pm.expect(json).to.have.property('articlesCount');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles"
          }
        },
        {
          "name": "Get articles with limit and offset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respects limit param', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.articles.length).to.be.at.most(5);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles?limit=5&offset=0"
          }
        },
        {
          "name": "Create article",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns created article', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('article');",
                  "  pm.expect(json.article).to.have.property('slug');",
                  "  pm.expect(json.article.title).to.eql('QA Test Article');",
                  "  pm.collectionVariables.set('articleSlug', json.article.slug);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"article\": {\n    \"title\": \"QA Test Article\",\n    \"description\": \"Created by automated test\",\n    \"body\": \"This article was created during API testing.\",\n    \"tagList\": [\"qa\", \"test\"]\n  }\n}"
            },
            "url": "{{baseUrl}}/articles"
          }
        },
        {
          "name": "Get article by slug",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns correct article', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.article.title).to.eql('QA Test Article');",
                  "  pm.expect(json.article).to.have.property('author');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles/{{articleSlug}}"
          }
        },
        {
          "name": "Update article",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Article was updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.article.title).to.eql('QA Test Article Updated');",
                  "  pm.collectionVariables.set('articleSlug', json.article.slug);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"article\": {\n    \"title\": \"QA Test Article Updated\"\n  }\n}"
            },
            "url": "{{baseUrl}}/articles/{{articleSlug}}"
          }
        },
        {
          "name": "Add comment to article",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns comment object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('comment');",
                  "  pm.expect(json.comment.body).to.eql('Test comment from API');",
                  "  pm.collectionVariables.set('commentId', json.comment.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": {\n    \"body\": \"Test comment from API\"\n  }\n}"
            },
            "url": "{{baseUrl}}/articles/{{articleSlug}}/comments"
          }
        },
        {
          "name": "Get comments for article",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns comments array', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('comments');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles/{{articleSlug}}/comments"
          }
        },
        {
          "name": "Delete comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 2xx on delete', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{baseUrl}}/articles/{{articleSlug}}/comments/{{commentId}}"
          }
        },
        {
          "name": "Delete article",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 2xx on delete', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{baseUrl}}/articles/{{articleSlug}}"
          }
        }
      ]
    },
    {
      "name": "Feed & Tags (HIGH)",
      "item": [
        {
          "name": "Get tags",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns tags array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('tags');",
                  "  pm.expect(json.tags).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tags"
          }
        },
        {
          "name": "Filter articles by tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns filtered articles', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.articles).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles?tag=qa"
          }
        },
        {
          "name": "Get user feed (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns feed articles', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('articles');",
                  "  pm.expect(json).to.have.property('articlesCount');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{baseUrl}}/articles/feed"
          }
        }
      ]
    },
    {
      "name": "Profiles (MEDIUM)",
      "item": [
        {
          "name": "Get user profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns profile object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('profile');",
                  "  pm.expect(json.profile).to.have.property('username');",
                  "  pm.expect(json.profile).to.have.property('following');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{baseUrl}}/profiles/qa_test"
          }
        }
      ]
    }
  ]
}
